{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellmos.local/skills/schemas/agent-v1.schema.json",
  "title": ".SKILLS Agent v1",
  "allOf": [
    {
      "$ref": "component-v1.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "agent"
        },
        "agent": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "description": {
              "type": ["string", "null"]
            },
            "prompt": {
              "type": ["string", "null"]
            },
            "tools": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "model": {
              "type": ["string", "null"]
            },
            "skills": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ellmos.local/skills/schemas/prompt-v1.schema.json",
  "title": ".SKILLS Prompt v1",
  "allOf": [
    {
      "$ref": "component-v1.schema.json"
    },
    {
      "type": "object",
      "properties": {
        "type": {
          "const": "prompt"
        },
        "prompt": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "variables": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "output_contract": {
              "type": "object"
            },
            "model_notes": {
              "type": "object"
            },
            "current_version_id": {
              "type": ["string", "null"]
            }
          }
        }
      }
    }
  ]
}
